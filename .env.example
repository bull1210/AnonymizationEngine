# Copy to .env — DEV ONLY. Production keys live in the KMS / HashiCorp Vault.
# Generate: openssl rand -hex 32  (tweak: openssl rand -hex 7)
ANON_DEFAULT_HMAC_SALT=replace_with_64_hex_chars
ANON_DEFAULT_FF31_KEY=replace_with_64_hex_chars
ANON_DEFAULT_FF31_TWEAK=replace_with_14_hex_chars
ANON_DEFAULT_VAULT_KEY=replace_with_64_hex_chars
GRAFANA_PASSWORD=change_me
